<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="container">
  <div class="page-head">
    <div>
      <h1 class="page-title"><%= receipt.receipt_no %></h1>
      <p class="subtle"><%= receipt.warehouse_code %> - <%= receipt.warehouse_name %></p>
    </div>
    <a class="button secondary" href="/receipts">Quay lại</a>
  </div>
  <%- include('partials/flash') %>

  <section class="panel detail-band">
    <div>
      <span class="metric-label">Trạng thái</span>
      <span class="status status-<%= receipt.status.toLowerCase() %>"><%= statusLabels[receipt.status] || receipt.status %></span>
    </div>
    <div>
      <span class="metric-label">Nguồn</span>
      <strong><%= receipt.source_factory || '' %></strong>
    </div>
    <div>
      <span class="metric-label">Ngày tạo</span>
      <strong><%= formatDate(receipt.created_at) %></strong>
    </div>
    <div>
      <span class="metric-label">Ngày xác nhận</span>
      <strong><%= formatDate(receipt.confirmed_at) || '-' %></strong>
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <h2 class="section-title">Dòng sản phẩm</h2>
      <% if (receipt.status === 'DRAFT') { %>
        <form action="/receipts/<%= receipt.id %>/confirm" method="post">
          <button type="submit">Xác nhận nhập kho</button>
        </form>
      <% } %>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
        <tr>
          <th>Sản phẩm</th>
          <th>Tên</th>
          <th>ĐVT</th>
          <th>Số lượng</th>
        </tr>
        </thead>
        <tbody>
        <% lines.forEach((line) => { %>
          <tr>
            <td><strong><%= line.product_code %></strong></td>
            <td><%= line.product_name %></td>
            <td><%= line.unit %></td>
            <td class="number"><%= line.quantity %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
