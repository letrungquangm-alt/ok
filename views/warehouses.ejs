<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="container">
  <div class="page-head">
    <div>
      <h1 class="page-title">Quản lý kho</h1>
      <p class="subtle">Có thể vận hành một kho hoặc mở rộng nhiều kho.</p>
    </div>
    <a class="button secondary" href="/api/warehouses" target="_blank">JSON</a>
  </div>
  <%- include('partials/flash') %>
  <section class="grid grid-2">
    <form class="panel" action="/warehouses" method="post">
      <h2 class="section-title"><%= warehouse.id ? 'Sửa kho' : 'Thêm kho' %></h2>
      <% if (warehouse.id) { %><input type="hidden" name="id" value="<%= warehouse.id %>"><% } %>
      <div class="form-grid">
        <div>
          <label>Mã kho</label>
          <input name="code" value="<%= warehouse.code || '' %>" required>
        </div>
        <div>
          <label>Tên kho</label>
          <input name="name" value="<%= warehouse.name || '' %>" required>
        </div>
        <div class="full">
          <label>Địa chỉ</label>
          <input name="address" value="<%= warehouse.address || '' %>">
        </div>
        <label class="checkbox-row">
          <input type="checkbox" name="active" <%= warehouse.active === false ? '' : 'checked' %>>
          Đang sử dụng
        </label>
      </div>
      <div class="actions">
        <button type="submit">Lưu kho</button>
        <% if (warehouse.id) { %><a class="button secondary" href="/warehouses">Hủy sửa</a><% } %>
      </div>
    </form>

    <div class="panel">
      <h2 class="section-title">Danh sách kho</h2>
      <div class="table-wrap">
        <table>
          <thead>
          <tr>
            <th>Mã</th>
            <th>Tên</th>
            <th>Địa chỉ</th>
            <th>Trạng thái</th>
            <th></th>
          </tr>
          </thead>
          <tbody>
          <% warehouses.forEach((item) => { %>
            <tr>
              <td><strong><%= item.code %></strong></td>
              <td><%= item.name %></td>
              <td><%= item.address || '' %></td>
              <td><span class="status <%= item.active ? 'status-completed' : 'status-cancelled' %>"><%= item.active ? 'Đang dùng' : 'Tạm ngưng' %></span></td>
              <td><a href="/warehouses/<%= item.id %>/edit">Sửa</a></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
