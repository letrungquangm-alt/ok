<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="container">
  <div class="page-head">
    <div>
      <h1 class="page-title">Quản lý khách hàng</h1>
      <p class="subtle">Thông tin giao dịch, địa chỉ, liên hệ và số điện thoại.</p>
    </div>
    <a class="button secondary" href="/api/customers" target="_blank">JSON</a>
  </div>
  <%- include('partials/flash') %>
  <section class="grid grid-2">
    <form class="panel" action="/customers" method="post">
      <h2 class="section-title"><%= customer.id ? 'Sửa khách hàng' : 'Thêm khách hàng' %></h2>
      <% if (customer.id) { %><input type="hidden" name="id" value="<%= customer.id %>"><% } %>
      <div class="form-grid">
        <div>
          <label>Mã khách hàng</label>
          <input name="code" value="<%= customer.code || '' %>" required>
        </div>
        <div>
          <label>Tên khách hàng</label>
          <input name="name" value="<%= customer.name || '' %>" required>
        </div>
        <div class="full">
          <label>Địa chỉ</label>
          <input name="address" value="<%= customer.address || '' %>">
        </div>
        <div>
          <label>Số điện thoại</label>
          <input name="phone" value="<%= customer.phone || '' %>">
        </div>
        <div>
          <label>Người liên hệ</label>
          <input name="contact_person" value="<%= customer.contact_person || '' %>">
        </div>
      </div>
      <div class="actions">
        <button type="submit">Lưu khách hàng</button>
        <% if (customer.id) { %><a class="button secondary" href="/customers">Hủy sửa</a><% } %>
      </div>
    </form>

    <div class="panel">
      <h2 class="section-title">Danh sách khách hàng</h2>
      <div class="table-wrap">
        <table>
          <thead>
          <tr>
            <th>Mã</th>
            <th>Tên</th>
            <th>Địa chỉ</th>
            <th>Điện thoại</th>
            <th>Liên hệ</th>
            <th></th>
          </tr>
          </thead>
          <tbody>
          <% customers.forEach((item) => { %>
            <tr>
              <td><strong><%= item.code %></strong></td>
              <td><%= item.name %></td>
              <td><%= item.address || '' %></td>
              <td><%= item.phone || '' %></td>
              <td><%= item.contact_person || '' %></td>
              <td><a href="/customers/<%= item.id %>/edit">Sửa</a></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
