<section class="panel">
  <form class="filter-bar" action="<%= action %>" method="get">
    <div>
      <label>Từ ngày</label>
      <input name="from" type="date" value="<%= from %>">
    </div>
    <div>
      <label>Đến ngày</label>
      <input name="to" type="date" value="<%= to %>">
    </div>
    <button type="submit">Xem báo cáo</button>
  </form>
</section>
