<section class="panel">
  <h2 class="section-title">Chi tiết phát sinh</h2>
  <div class="table-wrap">
    <table>
      <thead>
      <tr>
        <th>Thời gian</th>
        <th>Chứng từ</th>
        <th>Sản phẩm</th>
        <th>Kho</th>
        <th>Đối tác</th>
        <th>Số lượng</th>
      </tr>
      </thead>
      <tbody>
      <% movements.forEach((item) => { %>
        <tr>
          <td><%= formatDate(item.movement_at) %></td>
          <td><strong><%= item.document_no %></strong></td>
          <td><%= item.product_code %><br><span class="subtle"><%= item.product_name %></span></td>
          <td><%= item.warehouse_code %></td>
          <td><%= item.partner_name || '' %></td>
          <td class="number"><%= item.quantity %></td>
        </tr>
      <% }) %>
      <% if (movements.length === 0) { %>
        <tr><td colspan="6" class="empty">Không có phát sinh trong khoảng thời gian này.</td></tr>
      <% } %>
      </tbody>
    </table>
  </div>
</section>
