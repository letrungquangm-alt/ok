<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="container">
  <div class="page-head">
    <div>
      <h1 class="page-title">Báo cáo tồn kho hiện tại</h1>
      <p class="subtle">Số lượng tồn đang có theo từng sản phẩm và từng kho.</p>
    </div>
    <a class="button secondary" href="/api/inventory" target="_blank">JSON</a>
  </div>
  <%- include('partials/flash') %>
  <section class="panel">
    <div class="table-wrap">
      <table>
        <thead>
        <tr>
          <th>Mã sản phẩm</th>
          <th>Tên sản phẩm</th>
          <th>Nhóm</th>
          <th>Kho</th>
          <th>Tồn hiện tại</th>
          <th>ĐVT</th>
          <th>Cập nhật</th>
        </tr>
        </thead>
        <tbody>
        <% inventoryRows.forEach((row) => { %>
          <tr>
            <td><strong><%= row.product_code %></strong></td>
            <td><%= row.product_name %></td>
            <td><%= row.category || '' %></td>
            <td><%= row.warehouse_code %> - <%= row.warehouse_name %></td>
            <td class="number"><%= row.quantity %></td>
            <td><%= row.unit %></td>
            <td><%= formatDate(row.updated_at) %></td>
          </tr>
        <% }) %>
        <% if (inventoryRows.length === 0) { %>
          <tr><td colspan="7" class="empty">Chưa có tồn kho.</td></tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
